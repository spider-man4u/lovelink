rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /chat_images/{conversationId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    match /scene_images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
